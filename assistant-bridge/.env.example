# URL der FastAPI Middleware auf YunoHost (ohne trailing slash)
MIDDLEWARE_URL=https://api.yourdomain.tld

# JWT-Token für den Sync-Service (in FastAPI als X-Sync-Token Header)
# Diesen Wert aus der .env der Middleware übernehmen (SYNC_SERVICE_TOKEN)
SYNC_TOKEN=change-me-sync-token

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/assistant-bridge.log
